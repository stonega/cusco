[Desktop Entry]
Name=Cusco
Comment=Advanced AI chat for GNOME
Exec=cusco
Icon=@APP_ID@
Terminal=false
Type=Application
Categories=GNOME;GTK;Utility;Network;
StartupNotify=true
Actions=new-chat;quick-prompt;

[Desktop Action new-chat]
Name=New Chat
Exec=cusco --new-chat

[Desktop Action quick-prompt]
Name=Quick Prompt
Exec=cusco --quick-prompt
