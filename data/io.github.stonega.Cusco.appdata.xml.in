<?xml version="1.0" encoding="UTF-8"?>
<component type="desktop-application">
  <id>@APP_ID@</id>
  <metadata_license>CC0-1.0</metadata_license>
  <project_license>GPL-3.0-or-later</project_license>
  <name>Cusco</name>
  <summary>Advanced AI chat for GNOME</summary>
  <description>
    <p>
      Cusco is a native GNOME AI chat application focused on provider orchestration,
      memory control, tool use, durable artifacts, and a desktop-first conversation workflow.
    </p>
  </description>
  <launchable type="desktop-id">@APP_ID@.desktop</launchable>
  <developer id="io.github.stonega">
    <name>stonega</name>
  </developer>
  <url type="homepage">https://github.com/stonega/cusco</url>
  <content_rating type="oars-1.1" />
  <provides>
    <binary>cusco</binary>
  </provides>
  <releases>
    <release version="@VERSION@" date="2026-07-24" />
  </releases>
</component>
